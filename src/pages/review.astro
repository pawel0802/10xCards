---
import Layout from "@/layouts/Layout.astro";
import ReviewFlashcards from "@/components/ReviewFlashcards.tsx";
import Topbar from "@/components/Topbar.astro";
---

<Layout>
  <div class="bg-cosmic min-h-screen p-4">
    <Topbar />
    <div class="flex justify-center pt-8">
      <div class="w-full max-w-2xl rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
        <ReviewFlashcards initialCandidates={[]} client:load />
      </div>
    </div>
  </div>
</Layout>
