---
const { user } = Astro.locals;
const { hideDashboard = false } = Astro.props;
---

<div
  class="mb-4 flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/80"
>
  {
    user ? (
      <>
        <span class="text-blue-100/70">{user.email}</span>
        <div class="flex items-center gap-3">
          <a
            href="/dashboard"
            class:list={`inline-flex items-center gap-1.5 rounded-full bg-purple-600 px-3 py-1 text-xs font-semibold text-white transition hover:bg-purple-500${hideDashboard ? "hidden" : ""}`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <>
                <rect width="7" height="9" x="3" y="3" rx="1" />
                <rect width="7" height="5" x="14" y="3" rx="1" />
                <rect width="7" height="9" x="14" y="12" rx="1" />
                <rect width="7" height="5" x="3" y="16" rx="1" />
              </>
            </svg>
            Dashboard
          </a>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="inline-flex items-center gap-1 text-purple-300 transition-colors hover:text-purple-100 hover:underline"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <>
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                  <polyline points="16 17 21 12 16 7" />
                  <line x1="21" x2="9" y1="12" y2="12" />
                </>
              </svg>
              Sign out
            </button>
          </form>
        </div>
      </>
    ) : (
      <>
        <span class="text-blue-100/70">Not signed in</span>
        <div class="flex gap-3">
          <a href="/auth/signin" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Sign in
          </a>
          <a href="/auth/signup" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Sign up
          </a>
        </div>
      </>
    )
  }
</div>
